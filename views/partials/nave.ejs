<nav class="navbar navbar-expand-lg fixed-top" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); box-shadow: 0 2px 15px rgba(0,0,0,0.1);">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold fs-3 text-primary" href="/">Blogify</a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNavDropdown">
            <!-- Left side links -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link fw-medium" href="/">Home</a>
                </li>
                <% if (locals.user) { %>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/blogs/add-new">Add Blog</a>
                    </li>
                <% } %>
            </ul>

            <!-- Right side links -->
            <ul class="navbar-nav ms-auto align-items-center">
                <% if (locals.user) { %>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img 
                                src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" 
                                alt="<%= locals.user.fullName %>" 
                                width="34" 
                                height="34" 
                                class="rounded-circle border border-2 border-light shadow-sm" 
                                style="object-fit: cover;"
                                onerror="this.src='/imgs/default.png';">
                            <span class="fw-medium text-dark"><%= locals.user.fullName.split(" ")[0] %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item" href="/user/profile">👤 View Profile</a></li>
                            <li><a class="dropdown-item" href="#">⚙️ Settings</a></li>
                            <% if (locals.user.role === "ADMIN") { %>
                                <li><a class="dropdown-item text-info" href="/admin/users">🔧 Admin Panel</a></li>
                            <% } %>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger fw-medium" href="/user/logout">Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link fw-medium px-3" href="/user/signup">Sign Up</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary rounded-pill px-4 py-2 fw-medium" href="/user/signin">Sign In</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<!-- Global Error Alert -->
<% if (locals.error) { %>
    <div class="container mt-5 pt-5">
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <%= locals.error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<% } %>
