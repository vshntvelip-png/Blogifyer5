<style> :root { --primary: #6366f1; --dark: #0f172a; } body { font-family: 'Inter', system-ui, sans-serif; line-height: 1.7; color: #334155; } .navbar { box-shadow: 0 2px 15px rgba(0,0,0,0.1); } .hero { background: linear-gradient(rgba(15, 23, 42, 0.75), rgba(15, 23, 42, 0.85)), url('https://source.unsplash.com/random/1920x1080/?blog') center/cover no-repeat; color: white; padding: 160px 0 100px; text-align: center; } .card { transition: all 0.3s ease; border: none; border-radius: 16px; overflow: hidden; } .card:hover { transform: translateY(-12px); box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1); } .card-img-top { height: 240px; object-fit: cover; } .form-control, .form-select { border-radius: 10px; padding: 12px 16px; } .btn-primary { background: var(--primary); border: none; border-radius: 10px; padding: 12px 28px; font-weight: 600; } .blog-title { font-size: 1.35rem; line-height: 1.3; } </style>