<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - Blogify</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .signup-container {
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 420px;
        }
        h2 { text-align: center; margin-bottom: 25px; color: #333; }
        input[type="text"], input[type="email"], input[type="password"] {
            width: 100%; padding: 14px; margin: 10px 0; border: 1px solid #ccc;
            border-radius: 8px; font-size: 16px; box-sizing: border-box;
        }
        .otp-container { display: flex; gap: 12px; justify-content: center; margin: 15px 0; }
        .otp-box { 
            width: 55px; height: 65px; text-align: center; font-size: 28px; 
            font-weight: bold; border: 2px solid #ccc; border-radius: 10px;
        }
        button {
            width: 100%; padding: 14px; margin: 12px 0; border: none;
            border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer;
        }
        .btn-send-otp { background: #28a745; color: white; }
        .btn-create { background: #007bff; color: white; }
        .message { text-align: center; margin: 10px 0; min-height: 30px; font-weight: 500; }
    </style>
</head>
<body>
    <div class="signup-container">
        <h2>Create Account</h2>
        
        <form id="signupForm">
            <input type="text" id="fullName" placeholder="Full Name" required>
            <input type="email" id="email" placeholder="Email Address" required>
            <input type="password" id="password" placeholder="Password" required>

            <div class="otp-section">
                <label style="display:block; text-align:center; margin:10px 0; font-weight:600;">
                    Enter 6 Digit OTP
                </label>
                <div class="otp-container">
                    <input type="text" class="otp-box" maxlength="1" required>
                    <input type="text" class="otp-box" maxlength="1" required>
                    <input type="text" class="otp-box" maxlength="1" required>
                    <input type="text" class="otp-box" maxlength="1" required>
                    <input type="text" class="otp-box" maxlength="1" required>
                    <input type="text" class="otp-box" maxlength="1" required>
                </div>
            </div>

            <button type="button" id="sendOtpBtn" class="btn-send-otp">Send OTP</button>
            <button type="submit" class="btn-create">Create Account</button>
        </form>

        <div id="message" class="message"></div>
    </div>

    <!-- EmailJS Library -->
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

    <script>
        emailjs.init("lUYicfMscMJKE1eKj");

        const otpBoxes = document.querySelectorAll('.otp-box');
        const sendOtpBtn = document.getElementById('sendOtpBtn');
        const messageDiv = document.getElementById('message');

        // OTP Auto Focus
        otpBoxes.forEach((box, i) => {
            box.addEventListener('input', () => {
                box.value = box.value.replace(/[^0-9]/g, '');
                if (box.value.length === 1 && i < 5) otpBoxes[i+1].focus();
            });
        });

        function showMessage(msg, color = "red") {
            messageDiv.textContent = msg;
            messageDiv.style.color = color;
        }

        // Send OTP
        sendOtpBtn.addEventListener('click', async () => {
            const fullName = document.getElementById('fullName').value.trim();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;

            if (!fullName || !email || !password) {
                showMessage("All fields are required!");
                return;
            }

            sendOtpBtn.disabled = true;
            sendOtpBtn.textContent = "Sending...";

            try {
                const res = await fetch('/user/send-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName, email, password })
                });

                const data = await res.json();

                if (!res.ok) {
                    showMessage(data.message || "Server error");
                    return;
                }

                // Send Email via EmailJS
                await emailjs.send("service_to5286m", "YOUR_TEMPLATE_ID_HERE", {
                    to_name: fullName,
                    to_email: email,
                    otp: data.otp
                });

                showMessage("✅ OTP sent successfully! Check your email.", "green");

                // Cooldown Timer
                let time = 60;
                const timer = setInterval(() => {
                    time--;
                    sendOtpBtn.textContent = `Resend (${time}s)`;
                    if (time <= 0) {
                        clearInterval(timer);
                        sendOtpBtn.disabled = false;
                        sendOtpBtn.textContent = "Send OTP";
                    }
                }, 1000);

            } catch (err) {
                console.error(err);
                showMessage("Failed to send OTP: " + (err.text || err.message), "red");
            } finally {
                if (sendOtpBtn.textContent === "Sending...") {
                    sendOtpBtn.disabled = false;
                    sendOtpBtn.textContent = "Send OTP";
                }
            }
        });

        // Verify OTP
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            let otpValue = '';
            otpBoxes.forEach(box => otpValue += box.value);

            if (otpValue.length !== 6) {
                showMessage("Please enter full 6-digit OTP", "red");
                return;
            }

            try {
                const res = await fetch('/user/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        email: document.getElementById('email').value.trim(), 
                        otp: otpValue 
                    })
                });

                const data = await res.json();

                if (res.ok) {
                    alert("✅ Account Created Successfully!");
                    window.location.href = "/user/signup";
                } else {
                    showMessage(data.message || "Invalid OTP", "red");
                }
            } catch (err) {
                showMessage("Server error during verification", "red");
            }
        });
    </script>
</body>
</html>
