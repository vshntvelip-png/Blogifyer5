<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Home Page | Blogify</title>
    <style>
        body {
            background-color: #0b0c10 !important; /* Kept your dark theme */
            color: #f1f1f1;
        }
           .hero-section {
            background: linear-gradient(135deg, #669eea 0%, #764ba2 100%);
            color: black;
            padding: 80px 0;
            margin-bottom: 40px;
            border-radius: 0 0 50px 50px;
        }
        /* Style for full-width landscape cards */
        .blog-card-full {
            transition: all 0.3s ease;
            border: 1px solid #22252a;
            border-radius: 16px;
            overflow: hidden;
            background: #1a1a1a;
            margin-bottom: 24px; /* Space between rows */
            width: 100%;
        }
        .blog-card-full:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5);
            border-color: #3b82f6;
        }
        .card-img-horizontal {
            height: 100%;
            min-height: 200px;
            max-height: 250px;
            object-fit: cover;
            width: 100%;
        }
        .avatar-sm {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }
        .meta-text {
            font-size: 0.85rem;
            color: #a0aec0;
        }
    </style>
</head>
<body>
    <%- include("./partials/nave") %>

    <header class="hero-section text-center shadow">
        <div class="container">
            <h1 class="display-4 fw-bold">Welcome to Blogify</h1>
            <p class="lead text-light opacity-75">Discover stories, thinking, and expertise from writers on any topic.</p>
        </div>
    </header>

    <main class="container mb-5" style="max-width: 960px;">
        <div class="row">
            
            <% if (locals.blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="col-12"> <div class="card blog-card-full shadow-sm">
                            <div class="row g-0"> <div class="col-md-4">
                                    <img 
                                        src="<%= blog.coverImageURL ? blog.coverImageURL : '/images/default-blog.png' %>" 
                                        class="card-img-horizontal" 
                                        alt="Blog Cover"
                                        onerror="this.src='/images/default-blog.png';"
                                    >
                                </div>

                                <div class="col-md-8 d-flex flex-column justify-content-between p-4">
                                    <div>
                                        <div class="d-flex align-items-center mb-3">
                                            <% if (blog.createdBy) { %>
                                                <img src="<%= blog.createdBy.profileImageURL %>" class="avatar-sm me-2 shadow-sm">
                                                <span class="fw-semibold text-light me-2"><%= blog.createdBy.fullName %></span>
                                            <% } else { %>
                                                <span class="fw-semibold text-light me-2">Anonymous Writer</span>
                                            <% } %>
                                            <span class="text-muted mx-1">•</span>
                                            <span class="meta-text">
                                                <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                            </span>
                                        </div>

                                        <h3 class="card-title fw-bold text-white mb-2"><%= blog.title %></h3>
                                        <p class="card-text text-light opacity-75">
                                            <%= blog.body.substring(0, 180) %>...
                                        </p>
                                    </div>

                                    <div class="pt-3">
                                        <a href="/blogs/<%= blog._id %>" class="btn btn-primary rounded-pill px-4 btn-sm">Read More</a>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <h3 class="text-muted">No blogs found. Be the first to write one!</h3>
                    <a href="/blogs/add-new" class="btn btn-outline-primary mt-3">Create Blog</a>
                </div>
            <% } %>

        </div>
    </main>

    <%- include("./partials/scripts") %>
</body>
</html>